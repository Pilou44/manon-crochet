rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /creations/{id} {
      allow read: if resource.data.visible == true || request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
